---
/**
 * Layout principal — Tema fijo: dark-navy
 */
interface Props {
  title?: string;
  description?: string;
}

const {
  title       = 'Julio A. Ferraro Contactología — Bahía Blanca',
  description = 'Adaptación profesional de lentes de contacto y prótesis oculares en Bahía Blanca. Desde 1981. M.P. COPBA 163.',
} = Astro.props;

const siteUrl   = 'https://julioferraro.com.ar';
const ogImage   = `${siteUrl}/hero.webp`;
const canonical = siteUrl;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': siteUrl,
  name: 'Julio A. Ferraro Contactología',
  description: 'Adaptación profesional de lentes de contacto y prótesis oculares. Óptico Contactólogo — Protesista Ocular — UBA. M.P. COPBA 163.',
  url: siteUrl,
  telephone: '+5492916442425',
  foundingDate: '1981',
  address: {
    '@type': 'PostalAddress',
    streetAddress: "O'Higgins 27, Local 15",
    addressLocality: 'Bahía Blanca',
    addressRegion: 'Buenos Aires',
    addressCountry: 'AR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: -38.7196,
    longitude: -62.2661,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '09:00',
      closes: '16:00',
    },
  ],
  sameAs: [],
};
---

<!doctype html>
<html lang="es" data-theme="dark-navy">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
