<script>
  // ── Nota descartable ────────────────────────────────────
  const noticeEl = document.getElementById('t4-notice');
  const noticeCloseBtn = document.getElementById('t4-notice-close');

  function updateNoticeHeight() {
    const h = noticeEl && !noticeEl.classList.contains('t4-notice--hidden')
      ? noticeEl.offsetHeight
      : 0;
    document.documentElement.style.setProperty('--t4-notice-h', h + 'px');
  }

  // Medir en carga
  updateNoticeHeight();
  window.addEventListener('resize', updateNoticeHeight);

  noticeCloseBtn?.addEventListener('click', () => {
    noticeEl?.classList.add('t4-notice--hidden');
    setTimeout(() => {
      noticeEl?.remove();
      document.documentElement.style.setProperty('--t4-notice-h', '0px');
    }, 320);
  });

  // ── Navbar scroll ───────────────────────────────────────
  const navbar = document.getElementById('t4-navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  // ── Mobile burger ───────────────────────────────────────
  const burger = document.getElementById('t4-burger');
  const drawer = document.getElementById('t4-drawer');
  burger?.addEventListener('click', () => drawer?.classList.toggle('open'));
  drawer?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => drawer.classList.remove('open'));
  });

  // ── Intersection Observer (animaciones) ─────────────────
  const observer = new IntersectionObserver(
    entries => entries.forEach(e => {
      if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); }
    }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  // ── Formulario → /api/contact ───────────────────────────
  const form      = document.getElementById('t4-contactForm') as HTMLFormElement | null;
  const success   = document.getElementById('t4-formSuccess');
  const error     = document.getElementById('t4-formError');
  const submitBtn = form?.querySelector<HTMLButtonElement>('button[type="submit"]');

  form?.querySelectorAll('input, textarea').forEach(el => {
    el.addEventListener('input', () => (el as HTMLInputElement).setCustomValidity(''));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const emailEl = document.getElementById('t4-email') as HTMLInputElement;
    if (!emailEl?.value.trim()) {
      emailEl.setCustomValidity('Por favor ingrese su correo electrónico.');
      emailEl.reportValidity();
      return;
    }
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Enviando...'; }
    if (error)   error.style.display   = 'none';
    if (success) success.style.display = 'none';
    try {
      const body = {
        'bot-field': (form.querySelector<HTMLInputElement>('[name="bot-field"]')?.value ?? ''),
        nombre:   (document.getElementById('t4-nombre')   as HTMLInputElement)?.value.trim(),
        telefono: (document.getElementById('t4-telefono') as HTMLInputElement)?.value.trim(),
        email:    (document.getElementById('t4-email')    as HTMLInputElement)?.value.trim(),
        consulta: (document.getElementById('t4-consulta') as HTMLTextAreaElement)?.value.trim(),
      };
      const res  = await fetch('/api/contact', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify(body) });
      const json = await res.json();
      if (res.ok && json.ok) {
        if (success) success.style.display = 'flex';
        form.reset();
      } else throw new Error(json.error || 'Error');
    } catch (err: unknown) {
      if (error) {
        error.textContent = err instanceof Error ? err.message : 'Error al enviar.';
        error.style.display = 'flex';
      }
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = 'Enviar por Correo'; }
    }
  });

  // ── WhatsApp desde formulario ───────────────────────────
  document.getElementById('t4-waBtn')?.addEventListener('click', () => {
    const nombre   = (document.getElementById('t4-nombre')   as HTMLInputElement)?.value.trim();
    const email    = (document.getElementById('t4-email')    as HTMLInputElement)?.value.trim();
    const consultaEl = document.getElementById('t4-consulta') as HTMLTextAreaElement;
    const consulta = consultaEl?.value.trim();
    if (!consulta) { consultaEl?.setCustomValidity('Por favor ingrese su consulta.'); consultaEl?.reportValidity(); return; }
    consultaEl?.setCustomValidity('');
    let msg = 'Hola, les escribo desde su sitio web.';
    if (nombre) msg += `\n\nMi nombre es *${nombre}*`;
    if (email)  msg += ` y mi correo es ${email}.`;
    else if (nombre) msg += '.';
    msg += `\n\n*Consulta:* ${consulta}`;
    window.open(`https://wa.me/5492916442425?text=${encodeURIComponent(msg)}`, '_blank', 'noopener,noreferrer');
  });
</script>
