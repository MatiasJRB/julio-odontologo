---
/**
 * TEMPLATE 4 — Propuesta de distribución editorial
 *
 * Diferencias estructurales clave vs T1/T2/T3:
 *  • Navbar split (logo centrado, links distribuidos a ambos lados)
 *  • Hero dividido 60/40 con fondo fraccionado y stats floating
 *  • "Sobre nosotros" = fusión de Empresa + Quiénes en bento asimétrico
 *  • Servicios en dos paneles contrastados (no grids de cards)
 *  • Franja CTA full-width intermedia antes del contacto
 *  • Contacto 3 columnas: Info · Formulario · Mapa
 *  • Paleta nueva: verde profundo + arena cálida
 */
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import Map from '../components/Map.astro';
---

<Layout
  title="Julio A. Ferraro Contactología — Propuesta Layout T4"
  description="Adaptación profesional de lentes de contacto y prótesis oculares en Bahía Blanca. Desde 1981. M.P. 163."
>
  <!-- ====================================================
       NOTA DESCARTABLE — PROPUESTA T4
       ==================================================== -->
  <div class="t4-notice" id="t4-notice" role="note" aria-live="polite">
    <div class="t4-notice__inner">
      <div class="t4-notice__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </div>
      <p class="t4-notice__text">
        <strong>Propuesta T4 — Layout alternativo.</strong>
        Esta es una distribución estructural diferente a la que usted planteó, pensada como opción complementaria para evaluar.
        Los contenidos y datos son idénticos.
      </p>
    </div>
    <button class="t4-notice__close" id="t4-notice-close" aria-label="Cerrar nota">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>

  <!-- ====================================================
       NAVBAR SPLIT
       ==================================================== -->
  <nav class="t4-nav" id="t4-navbar">
    <div class="t4-nav__inner">
      <ul class="t4-nav__group t4-nav__group--left">
        <li><a href="#sobre">Sobre nosotros</a></li>
        <li><a href="#servicios">Servicios</a></li>
      </ul>

      <a href="#inicio" class="t4-nav__logo">
        <span class="t4-nav__logo-name">Julio A. Ferraro</span>
        <span class="t4-nav__logo-sub">Contactología · M.P. 163</span>
      </a>

      <ul class="t4-nav__group t4-nav__group--right">
        <li><a href="#contacto">Contacto</a></li>
        <li><a href="#contacto" class="t4-nav__cta">Solicitar Turno</a></li>
        <li><a href="/" class="t4-nav__back" aria-label="Volver a los temas T1/T2/T3">← T1/T2/T3</a></li>
      </ul>

      <!-- Mobile burger -->
      <button class="t4-nav__burger" id="t4-burger" aria-label="Menú">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile menu drawer -->
    <div class="t4-nav__drawer" id="t4-drawer">
      <a href="#sobre">Sobre nosotros</a>
      <a href="#servicios">Servicios</a>
      <a href="#contacto">Contacto</a>
      <a href="#contacto" class="t4-nav__cta">Solicitar Turno</a>
      <a href="/" class="t4-nav__back-mobile">← Volver a T1 / T2 / T3</a>
    </div>
  </nav>

  <!-- ====================================================
       HERO DIVIDIDO 60/40
       ==================================================== -->
  <section class="t4-hero" id="inicio">
    <div class="t4-hero__grid">

      <!-- Panel izquierdo: contenido -->
      <div class="t4-hero__left">
        <div class="t4-hero__content">
          <p class="t4-hero__eyebrow">Bahía Blanca · Desde 1981</p>
          <h1 class="t4-hero__title">
            <span class="t4-hero__title-name">Julio A.<br/>Ferraro</span>
            <span class="t4-hero__title-spec">Óptico Contactólogo<br/>Protesista Ocular</span>
          </h1>
          <p class="t4-hero__desc">
            Más de cuarenta años de dedicación exclusiva a la adaptación
            profesional de lentes de contacto y prótesis oculares.
          </p>
          <div class="t4-hero__actions">
            <a href="#servicios" class="t4-btn t4-btn--primary">Ver Servicios</a>
            <a href="#contacto" class="t4-btn t4-btn--ghost">Solicitar Turno</a>
          </div>
        </div>
      </div>

      <!-- Panel derecho: fondo con estadísticas -->
      <div class="t4-hero__right" aria-hidden="true">
        <div class="t4-hero__right-inner">
          <div class="t4-hero__stat-grid">
            <div class="t4-hero__stat">
              <span class="t4-hero__stat-num">+40</span>
              <span class="t4-hero__stat-label">Años de<br/>trayectoria</span>
            </div>
            <div class="t4-hero__stat">
              <span class="t4-hero__stat-num">163</span>
              <span class="t4-hero__stat-label">Matrícula<br/>profesional</span>
            </div>
            <div class="t4-hero__stat t4-hero__stat--wide">
              <Icon name="crosshair" size={18} />
              <span class="t4-hero__stat-label">Dedicación exclusiva<br/>a la especialidad</span>
            </div>
            <div class="t4-hero__stat t4-hero__stat--wide">
              <Icon name="map-pin" size={18} />
              <span class="t4-hero__stat-label">O'Higgins 27, Local 15<br/>Bahía Blanca</span>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ====================================================
       SOBRE NOSOTROS — bento asimétrico (Empresa + Quiénes)
       ==================================================== -->
  <section class="t4-sobre" id="sobre">
    <div class="t4-container">

      <!-- Encabezado minimal -->
      <header class="t4-section-head" data-animate>
        <span class="t4-label">01 · Sobre nosotros</span>
        <h2 class="t4-section-title">Profesionalismo al servicio de su visión</h2>
      </header>

      <!-- Bento grid -->
      <div class="t4-bento">

        <!-- Bloque A: Texto empresa (grande) -->
        <div class="t4-bento__cell t4-bento__cell--a" data-animate>
          <p class="t4-bento__overline">Nuestra Empresa</p>
          <p class="t4-bento__body">
            Somos <strong>JULIO A. FERRARO CONTACTOLOGÍA</strong>, con personal capacitado
            para asesorarlo profesionalmente en la elección de las lentes de contacto y
            prótesis oculares más apropiadas para su caso particular.
          </p>
          <p class="t4-bento__body" style="margin-top: 1rem;">
            Lo invitamos a conocer nuestras instalaciones y comprobar la calidad de
            atención que nos caracteriza. Estamos a su disposición.
          </p>
        </div>

        <!-- Bloque B: Año fundación (display grande) -->
        <div class="t4-bento__cell t4-bento__cell--b" data-animate>
          <span class="t4-bento__year">1981</span>
          <p class="t4-bento__year-label">Inicio ininterrumpido<br/>en contactología</p>
        </div>

        <!-- Bloque C: Exclusividad (highlight) -->
        <div class="t4-bento__cell t4-bento__cell--c" data-animate>
          <div class="t4-bento__exclusive-icon">
            <Icon name="crosshair" size={28} />
          </div>
          <h3 class="t4-bento__exclusive-title">Dedicación Exclusiva</h3>
          <p class="t4-bento__exclusive-text">
            Nos dedicamos <strong>exclusivamente</strong> a la adaptación de lentes de
            contacto y prótesis oculares. Esa especialización es la base de la
            confianza de nuestros pacientes.
          </p>
        </div>

        <!-- Bloque D: Valores (3 items apilados) -->
        <div class="t4-bento__cell t4-bento__cell--d" data-animate>
          <p class="t4-bento__overline">Por qué elegirnos</p>
          <ul class="t4-bento__values">
            <li class="t4-bento__value">
              <span class="t4-bento__value-icon"><Icon name="users" size={16} /></span>
              <div>
                <strong>Trato cercano y respetuoso</strong>
                <p>El trato amable que nos caracteriza fideliza a nuestros pacientes.</p>
              </div>
            </li>
            <li class="t4-bento__value">
              <span class="t4-bento__value-icon"><Icon name="activity" size={16} /></span>
              <div>
                <strong>Equipamiento actualizado</strong>
                <p>Crecimiento profesional continuo para cada caso.</p>
              </div>
            </li>
            <li class="t4-bento__value">
              <span class="t4-bento__value-icon"><Icon name="award" size={16} /></span>
              <div>
                <strong>Referentes en Bahía Blanca</strong>
                <p>Más de 40 años siendo la primera opción local.</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Bloque E: Timeline horizontal -->
        <div class="t4-bento__cell t4-bento__cell--e" data-animate>
          <p class="t4-bento__overline">Trayectoria</p>
          <div class="t4-timeline">
            <div class="t4-timeline__item">
              <div class="t4-timeline__dot"></div>
              <p class="t4-timeline__year">1981</p>
              <p class="t4-timeline__text">Inicio en el rubro óptico con dedicación exclusiva a contactología</p>
            </div>
            <div class="t4-timeline__item">
              <div class="t4-timeline__dot"></div>
              <p class="t4-timeline__year">Crecimiento</p>
              <p class="t4-timeline__text">Sin pausas, incorporando tecnología y formación continua</p>
            </div>
            <div class="t4-timeline__item">
              <div class="t4-timeline__dot t4-timeline__dot--active"></div>
              <p class="t4-timeline__year">Hoy</p>
              <p class="t4-timeline__text">Referentes en la zona por especialización y calidad de atención</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ====================================================
       SERVICIOS — paneles contrastados
       ==================================================== -->
  <section class="t4-servicios" id="servicios">
    <div class="t4-container">
      <header class="t4-section-head t4-section-head--light" data-animate>
        <span class="t4-label">02 · Qué hacemos</span>
        <h2 class="t4-section-title">Nuestros Servicios</h2>
        <p class="t4-section-sub">
          Adaptación profesional en todas sus variantes, con el equipamiento
          y la experiencia necesarios para cada caso.
        </p>
      </header>
    </div>

    <!-- Paneles side-by-side sin container wrapper -->
    <div class="t4-panels">

      <!-- Panel A: Lentes de Contacto -->
      <div class="t4-panel t4-panel--lentes">
        <div class="t4-panel__header">
          <div class="t4-panel__icon"><Icon name="eye" size={24} /></div>
          <h3 class="t4-panel__title">Lentes de Contacto</h3>
          <p class="t4-panel__sub">Adaptación en todas sus variantes</p>
        </div>
        <ul class="t4-panel__list">
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="droplets" size={14} /></span>
            <div>
              <strong>Flexibles</strong>
              <p>Máxima comodidad para uso diario y prolongado</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="wind" size={14} /></span>
            <div>
              <strong>Gas Permeables</strong>
              <p>Mayor oxigenación corneal y alta durabilidad</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="layers" size={14} /></span>
            <div>
              <strong>Blandos Estándar y Alto Grado</strong>
              <p>Para correcciones desde bajas hasta muy altas</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="refresh-cw" size={14} /></span>
            <div>
              <strong>Descartables</strong>
              <p>Reemplazo diario, quincenal o mensual</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="shield" size={14} /></span>
            <div>
              <strong>Protésicos</strong>
              <p>Apariencia natural para córneas alteradas</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="sparkles" size={14} /></span>
            <div>
              <strong>Cosméticos</strong>
              <p>Cambio de color con o sin corrección visual</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="zoom-in" size={14} /></span>
            <div>
              <strong>Multifocales</strong>
              <p>Lejos, intermedio y cerca en un solo lente</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="activity" size={14} /></span>
            <div>
              <strong>Queratocono y Córneas Irregulares</strong>
              <p>Diseños especiales para geometrías complejas</p>
            </div>
          </li>
        </ul>
      </div>

      <!-- Divisor central -->
      <div class="t4-panels__divider" aria-hidden="true">
        <div class="t4-panels__divider-line"></div>
        <div class="t4-panels__divider-badge">
          <Icon name="eye" size={20} />
        </div>
        <div class="t4-panels__divider-line"></div>
      </div>

      <!-- Panel B: Prótesis Oculares -->
      <div class="t4-panel t4-panel--protesis">
        <div class="t4-panel__header">
          <div class="t4-panel__icon"><Icon name="target" size={24} /></div>
          <h3 class="t4-panel__title">Prótesis Oculares</h3>
          <p class="t4-panel__sub">Adaptación con resultado natural</p>
        </div>
        <ul class="t4-panel__list">
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="circle" size={14} /></span>
            <div>
              <strong>Prótesis Estándar</strong>
              <p>Stock de formas y colores para adaptación inmediata</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="ruler" size={14} /></span>
            <div>
              <strong>Prótesis a Medida</strong>
              <p>Fabricada según la anatomía de cada paciente</p>
            </div>
          </li>
          <li class="t4-panel__item">
            <span class="t4-panel__item-icon"><Icon name="maximize" size={14} /></span>
            <div>
              <strong>Conformadores Orbitales</strong>
              <p>Para mantener el volumen y la forma de la órbita</p>
            </div>
          </li>
        </ul>

        <!-- Insumos embebidos en panel B -->
        <div class="t4-panel__insumos">
          <div class="t4-panel__insumos-icon"><Icon name="package" size={18} /></div>
          <div>
            <strong>Insumos de limpieza y mantenimiento</strong>
            <p>
              Contamos con productos de limpieza, mantenimiento y asesoramiento
              permanente para el cuidado de sus lentes o prótesis.
            </p>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ====================================================
       FRANJA CTA
       ==================================================== -->
  <section class="t4-cta-strip">
    <div class="t4-container t4-cta-strip__inner">
      <div>
        <p class="t4-cta-strip__label">¿Listo para dar el paso?</p>
        <h2 class="t4-cta-strip__title">Solicite su turno hoy</h2>
      </div>
      <div class="t4-cta-strip__actions">
        <a href="tel:+5492914540455" class="t4-btn t4-btn--primary">
          <Icon name="phone" size={16} />
          (0291) 454-0455
        </a>
        <a
          href="https://wa.me/5492916442425"
          target="_blank"
          rel="noopener noreferrer"
          class="t4-btn t4-btn--whatsapp"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
        <a href="#contacto" class="t4-btn t4-btn--ghost-light">Formulario de contacto</a>
      </div>
    </div>
  </section>

  <!-- ====================================================
       CONTACTO — 3 columnas: Info · Formulario · Mapa
       ==================================================== -->
  <section class="t4-contacto" id="contacto">
    <div class="t4-container">

      <header class="t4-section-head" data-animate>
        <span class="t4-label">03 · Contacto</span>
        <h2 class="t4-section-title">Estamos a su disposición</h2>
        <p class="t4-section-sub">
          Consúltenos sin compromiso. Le responderemos a la brevedad.
        </p>
      </header>

      <div class="t4-contacto__grid">

        <!-- Columna 1: Información -->
        <div class="t4-contacto__info" data-animate>
          <p class="t4-bento__overline">Datos de contacto</p>
          <ul class="t4-contacto__list">
            <li class="t4-contacto__item">
              <span class="t4-contacto__icon"><Icon name="map-pin" size={16} /></span>
              <div>
                <strong>Dirección</strong>
                <p>O'Higgins 27, Local 15<br/>Bahía Blanca, Buenos Aires</p>
              </div>
            </li>
            <li class="t4-contacto__item">
              <span class="t4-contacto__icon"><Icon name="phone" size={16} /></span>
              <div>
                <strong>Teléfono</strong>
                <p><a href="tel:+5492914540455">(0291) 454-0455</a></p>
              </div>
            </li>
            <li class="t4-contacto__item">
              <span class="t4-contacto__icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </span>
              <div>
                <strong>WhatsApp</strong>
                <p><a href="https://wa.me/5492916442425" target="_blank" rel="noopener noreferrer">Enviar mensaje directo</a></p>
              </div>
            </li>
            <li class="t4-contacto__item">
              <span class="t4-contacto__icon"><Icon name="clock" size={16} /></span>
              <div>
                <strong>Horario</strong>
                <p>Lunes a Viernes<br/>9:00 a 16:00 hs</p>
              </div>
            </li>
            <li class="t4-contacto__item">
              <span class="t4-contacto__icon"><Icon name="award" size={16} /></span>
              <div>
                <strong>Matrícula</strong>
                <p>M.P. 163</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Columna 2: Formulario -->
        <div class="t4-contacto__form-col" data-animate data-animate-delay="1">
          <p class="t4-bento__overline">Formulario de consulta</p>
          <form class="t4-form" id="t4-contactForm">
            <!-- Honeypot -->
            <p style="display:none" aria-hidden="true">
              <label>No completar: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </p>

            <div class="t4-form__row">
              <div class="t4-form__group">
                <label class="t4-form__label" for="t4-nombre">Nombre</label>
                <input class="t4-form__input" type="text" id="t4-nombre" name="nombre" placeholder="Su nombre" required />
              </div>
              <div class="t4-form__group">
