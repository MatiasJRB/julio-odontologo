<!-- ======================================================
     ESTILOS SCOPED AL TEMPLATE T4
     ====================================================== -->
<style>
  /* ── TOKENS propios de T4 ───────────────────────────── */
  :root {
    --t4-forest:      #1a3a2e;
    --t4-forest-md:   #254d3c;
    --t4-forest-lt:   #2e614c;
    --t4-sand:        #f5efe6;
    --t4-sand-md:     #ede5d8;
    --t4-sand-dk:     #d8cebf;
    --t4-gold:        #c4965a;
    --t4-gold-lt:     #d9b07c;
    --t4-text:        #1c2a24;
    --t4-text-muted:  #5a6e63;
    --t4-white:       #ffffff;
    --t4-radius:      6px;
    --t4-radius-lg:   12px;
    --t4-transition:  0.25s ease;
    --t4-max-w:       1200px;
    --t4-font-serif:  'Cormorant Garamond', Georgia, serif;
    --t4-font-sans:   'Inter', system-ui, sans-serif;
  }

  /* ── NOTA DESCARTABLE ───────────────────────────────── */
  .t4-notice {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 120;
    background: var(--t4-forest);
    color: rgba(255,255,255,0.92);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem clamp(1.25rem, 4vw, 2.5rem);
    font-size: 0.8rem;
    line-height: 1.5;
    border-bottom: 1px solid var(--t4-forest-lt);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .t4-notice.t4-notice--hidden {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
  }
  .t4-notice__inner {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    flex: 1;
  }
  .t4-notice__icon {
    color: var(--t4-gold-lt);
    flex-shrink: 0;
    margin-top: 1px;
  }
  .t4-notice__text { margin: 0; }
  .t4-notice__text strong {
    color: var(--t4-gold-lt);
    font-weight: 600;
  }
  .t4-notice__close {
    background: none;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--t4-transition), color var(--t4-transition);
  }
  .t4-notice__close:hover {
    background: rgba(255,255,255,0.12);
    color: var(--t4-white);
  }

  /* ── RESET BASE ─────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :global(body) {
    font-family: var(--t4-font-sans);
    background: var(--t4-sand);
    color: var(--t4-text);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  /* ── CONTAINER ──────────────────────────────────────── */
  .t4-container {
    max-width: var(--t4-max-w);
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 2.5rem);
  }

  /* ── LABEL / EYEBROW ────────────────────────────────── */
  .t4-label {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--t4-gold);
    margin-bottom: 0.75rem;
  }

  /* ── SECTION HEAD ───────────────────────────────────── */
  .t4-section-head {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .t4-section-title {
    font-family: var(--t4-font-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 400;
    color: var(--t4-forest);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }
  .t4-section-head--light .t4-section-title { color: var(--t4-forest); }
  .t4-section-sub {
    color: var(--t4-text-muted);
    max-width: 560px;
    margin-inline: auto;
    font-size: 0.95rem;
    line-height: 1.75;
  }

  /* ── BOTONES ─────────────────────────────────────────── */
  .t4-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--t4-radius);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    border: none;
    transition: var(--t4-transition);
    white-space: nowrap;
  }
  .t4-btn--primary {
    background: var(--t4-forest);
    color: var(--t4-white);
  }
  .t4-btn--primary:hover { background: var(--t4-forest-lt); }
  .t4-btn--ghost {
    background: transparent;
    color: var(--t4-forest);
    border: 1.5px solid var(--t4-forest);
  }
  .t4-btn--ghost:hover { background: var(--t4-forest); color: var(--t4-white); }
  .t4-btn--ghost-light {
    background: transparent;
    color: var(--t4-sand);
    border: 1.5px solid rgba(255,255,255,0.4);
  }
  .t4-btn--ghost-light:hover { background: rgba(255,255,255,0.12); }
  .t4-btn--whatsapp {
    background: #25D366;
    color: var(--t4-white);
  }
  .t4-btn--whatsapp:hover { background: #1ebe5a; }
  .t4-btn--sm { padding: 0.6rem 1.25rem; font-size: 0.75rem; }

  /* ── ANIMACIÓN entrada ──────────────────────────────── */
  [data-animate] {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  [data-animate].visible {
    opacity: 1;
    transform: none;
  }
  [data-animate-delay="1"] { transition-delay: 0.1s; }
  [data-animate-delay="2"] { transition-delay: 0.2s; }

  /* ═══════════════════════════════════════════════════════
     NAVBAR SPLIT
     ═══════════════════════════════════════════════════════ */
  .t4-nav {
    position: fixed;
    top: var(--t4-notice-h, 48px);
    left: 0;
    width: 100%;
    z-index: 100;
    background: rgba(245, 239, 230, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--t4-transition), background var(--t4-transition);
  }
  .t4-nav.scrolled {
    border-color: var(--t4-sand-dk);
    background: rgba(245, 239, 230, 0.97);
  }
  .t4-nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--t4-max-w);
    margin-inline: auto;
    padding: 0 clamp(1.25rem, 4vw, 2.5rem);
    height: 68px;
  }
  .t4-nav__group {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    min-width: 220px;
  }
  .t4-nav__group--right { justify-content: flex-end; }
  .t4-nav__group a {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--t4-text-muted);
    text-decoration: none;
    transition: color var(--t4-transition);
  }
  .t4-nav__group a:hover { color: var(--t4-forest); }
  .t4-nav__cta {
    background: var(--t4-forest) !important;
    color: var(--t4-white) !important;
    padding: 0.5rem 1.25rem;
    border-radius: var(--t4-radius);
  }
  .t4-nav__cta:hover { background: var(--t4-forest-lt) !important; }

  /* Volver a T1/T2/T3 */
  .t4-nav__back {
    font-size: 0.7rem !important;
    color: var(--t4-text-muted) !important;
    border: 1px solid var(--t4-sand-dk);
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    letter-spacing: 0.04em !important;
    transition: border-color var(--t4-transition), color var(--t4-transition), background var(--t4-transition);
  }
  .t4-nav__back:hover {
    color: var(--t4-forest) !important;
    border-color: var(--t4-forest-md) !important;
    background: var(--t4-sand-md);
  }
  .t4-nav__back-mobile {
    font-size: 0.8rem;
    color: var(--t4-text-muted);
    padding: 0.85rem clamp(1.25rem, 4vw, 2.5rem);
    border-top: 2px solid var(--t4-sand-dk);
    margin-top: 0.25rem;
    font-weight: 600;
  }
  .t4-nav__back-mobile:hover { background: var(--t4-sand-md); color: var(--t4-forest) !important; }

  .t4-nav__logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    line-height: 1.2;
  }
  .t4-nav__logo-name {
    font-family: var(--t4-font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--t4-forest);
    letter-spacing: 0.04em;
  }
  .t4-nav__logo-sub {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--t4-gold);
    font-weight: 500;
  }

  .t4-nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .t4-nav__burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--t4-forest);
    border-radius: 2px;
    transition: var(--t4-transition);
  }

  .t4-nav__drawer {
    display: none;
    flex-direction: column;
    gap: 0;
    background: var(--t4-sand);
    border-top: 1px solid var(--t4-sand-dk);
    padding: 0.5rem 0;
  }
  .t4-nav__drawer a {
    padding: 0.85rem clamp(1.25rem, 4vw, 2.5rem);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--t4-text);
    text-decoration: none;
    letter-spacing: 0.05em;
    border-bottom: 1px solid var(--t4-sand-md);
    transition: background var(--t4-transition);
  }
  .t4-nav__drawer a:hover { background: var(--t4-sand-md); }
  .t4-nav__drawer .t4-nav__cta {
    margin: 0.75rem clamp(1.25rem, 4vw, 2.5rem);
    border-radius: var(--t4-radius);
    text-align: center;
    border-bottom: none;
  }
  .t4-nav__drawer.open { display: flex; }

  @media (max-width: 768px) {
    .t4-nav__group { display: none; }
    .t4-nav__burger { display: flex; }
    .t4-nav__inner { justify-content: space-between; }
  }

  /* ═══════════════════════════════════════════════════════
     HERO DIVIDIDO
     ═══════════════════════════════════════════════════════ */
  .t4-hero {
    background: var(--t4-sand);
    padding-top: calc(68px + var(--t4-notice-h, 48px));
    display: flex;
    justify-content: center;
  }

  /* Grid 60/40 contenido dentro del max-width */
  .t4-hero__grid {
    width: min(var(--t4-max-w), calc(100% - clamp(2.5rem, 8vw, 5rem)));
    margin-inline: auto;
    display: grid;
    grid-template-columns: 60fr 40fr;
    min-height: calc(100svh - 68px - var(--t4-notice-h, 48px));
    border-radius: 0 0 var(--t4-radius-lg) var(--t4-radius-lg);
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
  }

  .t4-hero__left {
    background: var(--t4-sand);
    display: flex;
    align-items: center;
    padding: clamp(3rem, 6vw, 6rem) clamp(1.5rem, 5vw, 5rem);
  }

  .t4-hero__content { max-width: 520px; }

  .t4-hero__eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--t4-gold);
    margin-bottom: 1.5rem;
  }

  .t4-hero__title {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .t4-hero__title-name {
    font-family: var(--t4-font-serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 400;
    line-height: 0.95;
    color: var(--t4-forest);
    letter-spacing: -0.01em;
  }
  .t4-hero__title-spec {
    font-size: clamp(0.85rem, 1.5vw, 1rem);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--t4-gold);
    padding-left: 0.2rem;
    line-height: 1.5;
    margin-top: 0.25rem;
  }

  .t4-hero__desc {
    font-size: 0.95rem;
    color: var(--t4-text-muted);
    line-height: 1.8;
    margin-bottom: 2.5rem;
    max-width: 420px;
  }

  .t4-hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Panel derecho del hero */
  .t4-hero__right {
    background: var(--t4-forest);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
    position: relative;
  }
  .t4-hero__right::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--t4-forest-md) 0%, var(--t4-forest) 60%);
    opacity: 0.6;
  }
  .t4-hero__right-inner {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .t4-hero__stat-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .t4-hero__stat {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--t4-radius-lg);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    backdrop-filter: blur(4px);
    transition: background var(--t4-transition);
  }
  .t4-hero__stat:hover { background: rgba(255,255,255,0.1); }
  .t4-hero__stat--wide {
    grid-column: 1 / -1;
    flex-direction: row;
    align-items: center;
    gap: 0.75rem;
  }
  .t4-hero__stat--wide :global(svg) { color: var(--t4-gold-lt); flex-shrink: 0; }

  .t4-hero__stat-num {
    font-family: var(--t4-font-serif);
    font-size: 3rem;
    font-weight: 400;
    color: var(--t4-gold-lt);
    line-height: 1;
  }
  .t4-hero__stat-label {
    font-size: 0.72rem;
    color: rgba(255,255,255,0.65);
    letter-spacing: 0.06em;
    line-height: 1.4;
