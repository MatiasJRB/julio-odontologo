---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import Map  from '../components/Map.astro';
import '../styles/tokens.css';
import '../styles/base.css';
import '../themes/dark-navy.css';
import '../styles/components.css';
---

<Layout>
  <!-- ====================================================
       NAVBAR
       ==================================================== -->
  <nav class="navbar" id="navbar">
    <div class="container navbar__inner">
      <a href="#inicio" class="navbar__logo">
        <span class="navbar__logo-name">Julio A. Ferraro</span>
        <span class="navbar__logo-sub">Contactología</span>
      </a>

      <ul class="navbar__links" id="navLinks">
        <li><a href="#empresa">Nuestra Empresa</a></li>
        <li><a href="#quienes">Quiénes Somos</a></li>
        <li><a href="#hacemos">Qué Hacemos</a></li>
        <li><a href="#contacto" class="navbar__cta">Contacto</a></li>
      </ul>

      <button class="navbar__burger" id="burger" aria-label="Menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <!-- ====================================================
       HERO
       ==================================================== -->
  <section class="hero" id="inicio">

    <div class="container">
      <div class="hero__content">
        <p class="hero__eyebrow">Bahía Blanca — Desde 1981</p>
        <h1 class="hero__title">
          Julio Alejandro<strong>Ferraro</strong>
        </h1>
        <p class="hero__subtitle">Óptico Contactólogo · Protesista Ocular · UBA</p>
        <p class="hero__mp">M.P. COPBA 163</p>
        <p class="hero__description">
          Dedicación exclusiva a la adaptación profesional de <strong>LENTES DE CONTACTO</strong>
          y <strong>PRÓTESIS OCULARES</strong>. Más de cuarenta años acompañando a nuestros pacientes
          con conocimiento, equipamiento y atención personalizada.
        </p>
        <div class="hero__actions">
          <a href="#hacemos" class="btn btn-primary">Ver Servicios</a>
          <a href="#contacto" class="btn btn-outline">Solicitar Turno</a>
        </div>
      </div>
    </div>

    <div class="hero__scroll" aria-hidden="true">
      <Icon name="eye" size={16} />
      scroll
    </div>
  </section>

  <!-- ====================================================
       NUESTRA EMPRESA
       ==================================================== -->
  <section class="empresa" id="empresa">
    <div class="container">
      <div class="empresa__grid">
        <div>
          <span class="section-label" data-animate>Nuestra Empresa</span>
          <h2 class="section-title" data-animate data-animate-delay="1">
            Profesionalismo al servicio de su visión
          </h2>
          <div class="section-divider" data-animate data-animate-delay="2"></div>
          <p class="section-body" data-animate data-animate-delay="2">
            Somos <strong>JULIO A. FERRARO CONTACTOLOGÍA</strong>, contamos con personal
            capacitado para asesorarlo profesionalmente en la elección de las <strong>LENTES DE
            CONTACTO</strong> y <strong>PRÓTESIS OCULARES</strong> más apropiadas para su caso particular.
          </p>
          <br />
          <p class="section-body" data-animate data-animate-delay="3">
            Estamos en <strong>Bahía Blanca</strong>. Lo invitamos a conocer nuestras
            instalaciones y comprobar la calidad de atención que nos caracteriza.
            Estamos a su disposición.
          </p>
        </div>

        <div class="empresa__visual" data-animate data-animate-delay="2">
          <div class="empresa__photo-wrap">
            <img
              src="/empresa.webp"
              alt="Consultorio de contactología profesional"
              class="empresa__photo"
              width="1536"
              height="1024"
              loading="lazy"
              decoding="async"
            />
            <div class="empresa__photo-card">
              <div class="empresa__card-icon-wrap">
                <Icon name="eye" size={22} />
              </div>
              <h3 class="empresa__card-title">Atención Personalizada</h3>
              <div class="empresa__card-location">
                <Icon name="map-pin" size={13} />
                O'Higgins 27, Local 15 · Bahía Blanca
              </div>
              <div class="empresa__stats">
                <div class="empresa__stat">
                  <div class="empresa__stat-num">+40</div>
                  <div class="empresa__stat-label">Años de experiencia</div>
                </div>
                <div class="empresa__stat">
                  <div class="empresa__stat-num">163</div>
                  <div class="empresa__stat-label">Matrícula profesional</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       QUIÉNES SOMOS
       ==================================================== -->
  <section class="quienes" id="quienes">
    <div class="container">
      <div class="quienes__inner">
        <div>
          <span class="section-label" data-animate>Quiénes Somos</span>
          <h2 class="section-title" data-animate data-animate-delay="1">
            Dedicación exclusiva a nuestra especialidad
          </h2>
          <div class="section-divider" data-animate data-animate-delay="2"></div>
          <p class="section-body" data-animate data-animate-delay="2">
            Nos dedicamos exclusivamente a la adaptación de <strong>LENTES DE
            CONTACTO</strong> y <strong>PRÓTESIS OCULARES</strong>. En la zona nos conocen por esa dedicación
            exclusiva y por el trato amable y respetuoso que hace que los pacientes
            nos elijan.
          </p>

          <div class="quienes__values" data-animate data-animate-delay="3">
            <div class="quienes__value">
              <div class="quienes__value-icon">
                <Icon name="crosshair" size={20} />
              </div>
              <div>
                <h4 class="quienes__value-title">Especialización Total</h4>
                <p class="quienes__value-text">
                  Dedicación exclusiva a <strong>LENTES DE CONTACTO</strong> y <strong>PRÓTESIS OCULARES</strong>,
                  con resultados concretos y garantía de adaptación.
                </p>
              </div>
            </div>
            <div class="quienes__value">
              <div class="quienes__value-icon">
                <Icon name="users" size={20} />
              </div>
              <div>
                <h4 class="quienes__value-title">Atención Personalizada</h4>
                <p class="quienes__value-text">
                  El trato amable y respetuoso que nos caracteriza es la base
                  de la confianza de nuestros pacientes.
                </p>
              </div>
            </div>
            <div class="quienes__value">
              <div class="quienes__value-icon">
                <Icon name="activity" size={20} />
              </div>
              <div>
                <h4 class="quienes__value-title">Equipamiento Actualizado</h4>
                <p class="quienes__value-text">
                  Crecimiento profesional continuo para brindar el conocimiento
                  y equipamiento necesarios para respaldar cada práctica.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="quienes__photo-col" data-animate data-animate-delay="2">
          <div class="quienes__photo-wrap">
            <img
              src="/quienes.png"
              alt="Profesional de la contactología"
              class="quienes__photo"
              loading="lazy"
            />
            <div class="quienes__photo-badge">
              <Icon name="award" size={18} />
              <span>Más de 40 años<br/>de trayectoria</span>
            </div>
          </div>

          <div class="quienes__timeline" data-animate data-animate-delay="3">
            <div class="quienes__tl-item">
              <div class="quienes__tl-dot"></div>
              <p class="quienes__tl-year">1981</p>
              <p class="quienes__tl-text">
                Inicio ininterrumpido en el rubro óptico con dedicación exclusiva
                a la contactología y a la adaptación de prótesis oculares.
              </p>
            </div>
            <div class="quienes__tl-item">
              <div class="quienes__tl-dot"></div>
              <p class="quienes__tl-year">Crecimiento continuo</p>
              <p class="quienes__tl-text">
                Sin parar de crecer profesionalmente para brindar a nuestros
                pacientes el mejor nivel de atención.
              </p>
            </div>
            <div class="quienes__tl-item">
              <div class="quienes__tl-dot"></div>
              <p class="quienes__tl-year">Hoy</p>
              <p class="quienes__tl-text">
                Referentes en Bahía Blanca por la dedicación exclusiva a la
                especialidad y la calidad de atención que ofrecemos.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ====================================================
       QUÉ HACEMOS
       ==================================================== -->
  <section class="hacemos" id="hacemos">

    <div class="container hacemos__container">
      <div class="hacemos__header" data-animate>
        <span class="section-label">Qué Hacemos</span>
        <h2 class="section-title">Nuestros Servicios</h2>
        <div class="section-divider" style="margin-inline: auto;"></div>
        <p class="section-body">
          Adaptación profesional de <strong>LENTES DE CONTACTO</strong> y <strong>PRÓTESIS OCULARES</strong> en todas
          sus variantes, con el equipamiento y la experiencia necesarios para garantizar el éxito en cada adaptación.
        </p>
      </div>

      <!-- Lentes de Contacto -->
      <div class="hacemos__category" data-animate>
        <div class="hacemos__category-header">
          <div class="hacemos__category-icon">
            <Icon name="eye" size={26} />
          </div>
          <div>
            <h3 class="hacemos__category-title">Lentes de Contacto</h3>
            <p class="hacemos__category-sub">Adaptación profesional en todas sus variantes</p>
          </div>
        </div>

        <div class="hacemos__services-grid">
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="droplets" size={18} /></div>
            <h4 class="hacemos__service-name">Flexibles</h4>
            <p class="hacemos__service-desc">Máxima comodidad para uso diario y prolongado en el tiempo</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="wind" size={18} /></div>
            <h4 class="hacemos__service-name">Gas Permeables</h4>
            <p class="hacemos__service-desc">Mayor oxigenación corneal y alta durabilidad</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="layers" size={18} /></div>
            <h4 class="hacemos__service-name">Blandos Estándar y Alto Grado</h4>
            <p class="hacemos__service-desc">Para correcciones desde bajas hasta muy altas</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="refresh-cw" size={18} /></div>
            <h4 class="hacemos__service-name">Blandos Descartables</h4>
            <p class="hacemos__service-desc">Reemplazo diario, quincenal o mensual</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="shield" size={18} /></div>
            <h4 class="hacemos__service-name">Protésicos</h4>
            <p class="hacemos__service-desc">Apariencia natural para córneas alteradas</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="sparkles" size={18} /></div>
            <h4 class="hacemos__service-name">Cosméticos</h4>
            <p class="hacemos__service-desc">Cambio de color con o sin corrección visual</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="zoom-in" size={18} /></div>
            <h4 class="hacemos__service-name">Multifocales</h4>
            <p class="hacemos__service-desc">Lejos, intermedio y cerca en un solo lente</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="activity" size={18} /></div>
            <h4 class="hacemos__service-name">Queratocono y Córneas Irregulares</h4>
            <p class="hacemos__service-desc">Diseños especiales para geometrías complejas</p>
          </div>
        </div>
      </div>

      <!-- Prótesis Oculares -->
      <div class="hacemos__category" data-animate data-animate-delay="1">
        <div class="hacemos__category-header">
          <div class="hacemos__category-icon">
            <Icon name="target" size={26} />
          </div>
          <div>
            <h3 class="hacemos__category-title">Prótesis Oculares</h3>
            <p class="hacemos__category-sub">Adaptación profesional con resultado natural</p>
          </div>
        </div>

        <div class="hacemos__services-grid hacemos__services-grid--3">
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="circle" size={18} /></div>
            <h4 class="hacemos__service-name">Prótesis Estándar</h4>
            <p class="hacemos__service-desc">Stock de formas y colores para adaptación inmediata</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="ruler" size={18} /></div>
            <h4 class="hacemos__service-name">Prótesis a Medida</h4>
            <p class="hacemos__service-desc">Fabricada según la anatomía de cada paciente</p>
          </div>
          <div class="hacemos__service-card">
            <div class="hacemos__service-icon"><Icon name="maximize" size={18} /></div>
            <h4 class="hacemos__service-name">Conformadores Orbitales</h4>
            <p class="hacemos__service-desc">Para mantener el volumen y la forma de la cavidad orbital</p>
          </div>
        </div>
      </div>

      <!-- Insumos -->
      <div class="hacemos__insumos" data-animate data-animate-delay="2">
        <div class="hacemos__insumos-icon">
          <Icon name="package" size={22} />
        </div>
        <div>
          <strong>Insumos de limpieza y mantenimiento</strong>
          <p>Contamos con productos de limpieza, mantenimiento y asesoramiento permanente para el cuidado de sus lentes o prótesis.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====================================================
       CONTACTO
       ==================================================== -->
  <section class="contacto" id="contacto">
    <div class="container">
      <div class="contacto__grid">
        <div>
          <span class="section-label" data-animate>Contacto</span>
          <h2 class="section-title" data-animate data-animate-delay="1">
            Estamos a su disposición
          </h2>
          <div class="section-divider" data-animate data-animate-delay="2"></div>
          <p class="section-body" data-animate data-animate-delay="2">
            Consúltenos sin compromiso. Complete el formulario y su consulta
            se enviará directamente a nuestro WhatsApp.
          </p>

          <div class="contacto__info" data-animate data-animate-delay="3">
            <div class="contacto__item">
              <div class="contacto__item-icon">
                <Icon name="map-pin" size={18} />
              </div>
              <div>
                <p class="contacto__item-title">Dirección</p>
                <p class="contacto__item-text">O'Higgins 27, Local 15<br/>Bahía Blanca, Buenos Aires</p>
              </div>
            </div>
            <div class="contacto__item">
              <div class="contacto__item-icon">
                <Icon name="phone" size={18} />
              </div>
              <div>
                <p class="contacto__item-title">Teléfono</p>
                <p class="contacto__item-text">
                  <a href="tel:+5492916442425">(291) 644-2425</a>
                </p>
              </div>
            </div>
            <div class="contacto__item">
              <div class="contacto__item-icon">
                <Icon name="award" size={18} />
              </div>
              <div>
                <p class="contacto__item-title">Matrícula</p>
                <p class="contacto__item-text">M.P. COPBA 163</p>
              </div>
            </div>
            <div class="contacto__item">
              <div class="contacto__item-icon contacto__item-icon--wa">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </div>
              <div>
                <p class="contacto__item-title">WhatsApp</p>
                <p class="contacto__item-text">
                  <a href="https://wa.me/5492916442425" target="_blank" rel="noopener noreferrer">Enviar mensaje directo</a>
                </p>
              </div>
            </div>
            <div class="contacto__item">
              <div class="contacto__item-icon">
                <Icon name="clock" size={18} />
              </div>
              <div>
                <p class="contacto__item-title">Horario de atención</p>
                <p class="contacto__item-text">Lunes a Viernes<br/>9:00 a 16:00 hs</p>
              </div>
            </div>
          </div>
        </div>

        <div data-animate data-animate-delay="2">
          <form
            class="form"
            id="contactForm"
          >
            <!-- honeypot: campo oculto para detectar bots -->
            <p style="display:none" aria-hidden="true">
              <label>No completar: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
            </p>

            <!-- Motivo: selector inline -->
            <div class="form__group">
              <label class="form__label">Motivo de contacto</label>
              <div class="form__motivo-toggle">
                <button type="button" class="form__motivo-btn selected" data-motivo="consulta">
                  <Icon name="message-circle" size={16} />
                  Consulta general
                </button>
                <button type="button" class="form__motivo-btn" data-motivo="turno">
                  <Icon name="calendar" size={16} />
                  Solicitar turno
                </button>
              </div>
            </div>

            <div class="form__group">
              <label class="form__label" for="nombre">Nombre</label>
              <input class="form__input" type="text" id="nombre" name="nombre" placeholder="Su nombre" required autocomplete="name" />
            </div>

            <div class="form__turno-fields" id="turnoFields" style="display:none">
              <p class="form__field-hint">Seleccione día y horario preferido (sujeto a disponibilidad)</p>

              <!-- Mini calendario custom -->
              <div class="form__group">
                <label class="form__label">Día preferido</label>
                <div class="picker-cal" id="pickerCal">
                  <div class="picker-cal__nav">
                    <button type="button" class="picker-cal__arrow" id="calPrev" aria-label="Mes anterior">
                      <Icon name="arrow-left" size={16} />
                    </button>
                    <span class="picker-cal__month" id="calMonth"></span>
                    <button type="button" class="picker-cal__arrow" id="calNext" aria-label="Mes siguiente">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </button>
                  </div>
                  <div class="picker-cal__weekdays">
                    <span>Lu</span><span>Ma</span><span>Mi</span><span>Ju</span><span>Vi</span><span>Sá</span><span>Do</span>
                  </div>
                  <div class="picker-cal__days" id="calDays"></div>
                </div>
                <input type="hidden" id="dia" name="dia" />
              </div>

              <!-- Selector de hora: chips -->
              <div class="form__group">
                <label class="form__label">Horario preferido</label>
                <div class="picker-time" id="pickerTime">
                  <button type="button" class="picker-time__chip" data-hora="09:00">9:00</button>
                  <button type="button" class="picker-time__chip" data-hora="10:00">10:00</button>
                  <button type="button" class="picker-time__chip" data-hora="11:00">11:00</button>
                  <button type="button" class="picker-time__chip" data-hora="12:00">12:00</button>
                  <button type="button" class="picker-time__chip" data-hora="13:00">13:00</button>
                  <button type="button" class="picker-time__chip" data-hora="14:00">14:00</button>
                  <button type="button" class="picker-time__chip" data-hora="15:00">15:00</button>
                  <button type="button" class="picker-time__chip" data-hora="16:00">16:00</button>
                </div>
                <input type="hidden" id="hora" name="hora" />
              </div>
            </div>

            <div class="form__group">
              <label class="form__label" for="consulta">Consulta</label>
              <textarea
                class="form__textarea"
                id="consulta"
                name="consulta"
                placeholder="Describa brevemente su consulta..."
                required
              ></textarea>
            </div>

            <button type="submit" class="btn btn-whatsapp form__submit" id="whatsappBtn">
