<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('navLinks');
  burger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });
  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => navLinks.classList.remove('open'));
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  if (new URLSearchParams(window.location.search).get('submitted') === 'true') {
    const s = document.getElementById('formSuccess');
    if (s) s.style.display = 'flex';
  }

  // ── WhatsApp desde formulario ─────────────────────────────
  // TODO: reemplazar con el número privado de WhatsApp de Julio cuando se confirme
  const WA_NUMBER = '5492916442425';

  document.getElementById('whatsappBtn')?.addEventListener('click', () => {
    const nombre   = (document.getElementById('nombre')   as HTMLInputElement)?.value.trim();
    const telefono = (document.getElementById('telefono') as HTMLInputElement)?.value.trim();
    const consulta = (document.getElementById('consulta') as HTMLTextAreaElement)?.value.trim();

    let msg = 'Hola, les escribo desde su sitio web.';
    if (nombre)   msg += `\n\nMi nombre es *${nombre}*`;
    if (telefono) msg += ` y mi teléfono es ${telefono}.`;
    else if (nombre) msg += '.';
    if (consulta) msg += `\n\n*Consulta:* ${consulta}`;

    const url = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
    window.open(url, '_blank', 'noopener,noreferrer');
  });

  // ── Theme picker (3 temas) ────────────────────────────────
  const pills = document.querySelectorAll('.theme-pill');
  const html  = document.documentElement;

  function setTheme(t) {
    html.setAttribute('data-theme', t);
    localStorage.setItem('ferraro-theme', t);
    pills.forEach(p => p.classList.toggle('active', p.dataset.theme === t));
  }

  const saved = localStorage.getItem('ferraro-theme') || 'dark-navy';
  setTheme(saved);

  pills.forEach(pill => {
    pill.addEventListener('click', () => setTheme(pill.dataset.theme));
  });
</script>
