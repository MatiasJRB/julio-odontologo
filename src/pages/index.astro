<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 60);
  });

  const burger = document.getElementById('burger');
  const navLinks = document.getElementById('navLinks');
  burger?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
  });
  navLinks?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => navLinks.classList.remove('open'));
  });

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

  // ── Formulario → WhatsApp ─────────────────────
  const WA_NUMBER = '5492916442425';
  const contactForm = document.getElementById('contactForm') as HTMLFormElement | null;
  const turnoFields = document.getElementById('turnoFields');
  const diaHidden = document.getElementById('dia') as HTMLInputElement | null;
  const horaHidden = document.getElementById('hora') as HTMLInputElement | null;
  const motivoBtns = document.querySelectorAll<HTMLButtonElement>('.form__motivo-btn');

  let selectedMotivo = 'consulta';

  // ── Mini calendario custom ──
  const calDays = document.getElementById('calDays');
  const calMonth = document.getElementById('calMonth');
  const calPrev = document.getElementById('calPrev');
  const calNext = document.getElementById('calNext');

  const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  const today = new Date();
  today.setHours(0,0,0,0);
  const maxDate = new Date(today);
  maxDate.setMonth(maxDate.getMonth() + 3);

  let calYear = today.getFullYear();
  let calMon = today.getMonth();
  let selectedDay: string = '';

  function renderCal() {
    if (!calDays || !calMonth) return;
    calMonth.textContent = `${MESES[calMon]} ${calYear}`;

    // Primer día del mes (lunes = 0)
    const first = new Date(calYear, calMon, 1);
    let startDay = first.getDay() - 1;
    if (startDay < 0) startDay = 6;
    const daysInMonth = new Date(calYear, calMon + 1, 0).getDate();

    let html = '';
    // Espacios vacíos
    for (let i = 0; i < startDay; i++) {
      html += '<span class="picker-cal__day picker-cal__day--empty"></span>';
    }
    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(calYear, calMon, d);
      const iso = `${calYear}-${String(calMon+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const isPast = date < today;
      const isFuture = date > maxDate;
      const isToday = date.getTime() === today.getTime();
      const isSelected = iso === selectedDay;
      const isSun = date.getDay() === 0;

      let cls = 'picker-cal__day';
      if (isPast || isFuture || isSun) cls += ' picker-cal__day--disabled';
      if (isToday) cls += ' picker-cal__day--today';
      if (isSelected) cls += ' picker-cal__day--selected';

      html += `<button type="button" class="${cls}" data-date="${iso}">${d}</button>`;
    }
    calDays.innerHTML = html;

    // Click en día
    calDays.querySelectorAll<HTMLButtonElement>('.picker-cal__day:not(.picker-cal__day--disabled):not(.picker-cal__day--empty)').forEach(btn => {
      btn.addEventListener('click', () => {
        selectedDay = btn.dataset.date ?? '';
        if (diaHidden) diaHidden.value = selectedDay;
        renderCal();
      });
    });

    // Habilitar/deshabilitar flechas
    if (calPrev) {
      (calPrev as HTMLButtonElement).disabled = (calYear === today.getFullYear() && calMon === today.getMonth());
    }
    if (calNext) {
      (calNext as HTMLButtonElement).disabled = (calYear === maxDate.getFullYear() && calMon === maxDate.getMonth());
    }
  }

  calPrev?.addEventListener('click', () => {
    calMon--;
    if (calMon < 0) { calMon = 11; calYear--; }
    renderCal();
  });
  calNext?.addEventListener('click', () => {
    calMon++;
    if (calMon > 11) { calMon = 0; calYear++; }
    renderCal();
  });

  renderCal();

  // ── Time chips ──
  const timeChips = document.querySelectorAll<HTMLButtonElement>('.picker-time__chip');
  timeChips.forEach(chip => {
    chip.addEventListener('click', () => {
      timeChips.forEach(c => c.classList.remove('selected'));
      chip.classList.add('selected');
      if (horaHidden) horaHidden.value = chip.dataset.hora ?? '';
    });
  });

  // Toggle motivo
  motivoBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      selectedMotivo = btn.dataset.motivo ?? 'consulta';
      motivoBtns.forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');

      if (turnoFields) {
        turnoFields.style.display = selectedMotivo === 'turno' ? 'block' : 'none';
      }
    });
  });

  // Limpiar errores de validación mientras el usuario escribe
  contactForm?.querySelectorAll('input, textarea, select').forEach(el => {
    el.addEventListener('input', () => (el as HTMLInputElement).setCustomValidity(''));
  });

  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault();

    const nombre     = (document.getElementById('nombre')   as HTMLInputElement)?.value.trim();
    const consultaEl = document.getElementById('consulta') as HTMLTextAreaElement;
    const consulta   = consultaEl?.value.trim();

    if (!nombre) {
      const el = document.getElementById('nombre') as HTMLInputElement;
      el?.setCustomValidity('Por favor ingrese su nombre.');
      el?.reportValidity();
      return;
    }

    if (!consulta) {
      consultaEl?.setCustomValidity('Por favor ingrese su consulta.');
      consultaEl?.reportValidity();
      return;
    }
    consultaEl?.setCustomValidity('');

    let msg = 'Hola, les escribo desde su sitio web.';
    msg += `\n\nMi nombre es *${nombre}*.`;

    if (selectedMotivo === 'turno') {
      const dia  = diaHidden?.value ?? '';
      const hora = horaHidden?.value ?? '';
      if (dia || hora) {
        msg += '\n\n*Solicitud de turno:*';
        if (dia) {
          const [y, m, d] = dia.split('-');
          msg += ` ${d}/${m}/${y}`;
        }
        if (hora) msg += ` a las ${hora} hs`;
      }
    }

    msg += `\n\n*Consulta:* ${consulta}`;

    const url = `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`;
    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>
